{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and stats",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "stats": {
          "type": "object",
          "properties": {
            "streak": { "type": "number" },
            "totalCardsViewed": { "type": "number" },
            "totalCardsMastered": { "type": "number" }
          }
        },
        "createdAt": { "type": "string" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Deck": {
      "title": "Deck",
      "description": "A deck of flashcards",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string" },
        "lastStudiedAt": { "type": "string" }
      },
      "required": ["id", "userId", "name", "createdAt"]
    },
    "Flashcard": {
      "title": "Flashcard",
      "description": "A single flashcard inside a deck",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "deckId": { "type": "string" },
        "userId": { "type": "string" },
        "front": { "type": "string" },
        "back": { "type": "string" },
        "hint": { "type": "string" },
        "mastered": { "type": "boolean" },
        "difficulty": { "type": "string" },
        "reviewCount": { "type": "number" }
      },
      "required": ["id", "deckId", "userId", "front", "back"]
    },
    "StudySession": {
      "title": "StudySession",
      "description": "Analytics record for a completed study session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "deckId": { "type": "string" },
        "cardsStudied": { "type": "number" },
        "correctAnswers": { "type": "number" },
        "incorrectAnswers": { "type": "number" },
        "durationSeconds": { "type": "number" },
        "timestamp": { "type": "string" }
      },
      "required": ["id", "userId", "deckId", "cardsStudied", "correctAnswers", "incorrectAnswers", "durationSeconds", "timestamp"]
    },
    "Note": {
      "title": "Note",
      "description": "User notes generated by AI",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "userId", "title", "content", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "users/{userId}/decks/{deckId}": {
      "schema": { "$ref": "#/entities/Deck" },
      "description": "User's decks"
    },
    "users/{userId}/decks/{deckId}/cards/{cardId}": {
      "schema": { "$ref": "#/entities/Flashcard" },
      "description": "Cards in a deck"
    },
    "users/{userId}/sessions/{sessionId}": {
      "schema": { "$ref": "#/entities/StudySession" },
      "description": "Study sessions for a user"
    },
    "users/{userId}/notes/{noteId}": {
      "schema": { "$ref": "#/entities/Note" },
      "description": "Notes for a user"
    }
  }
}
